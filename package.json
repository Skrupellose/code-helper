{
  "name": "@skrupellose/code-helper",
  "version": "0.2.0",
  "description": "通用 agent 协作流程 CLI，用于初始化项目规则、维护记忆、生成计划文档并检查协作规范。",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Skrupellose/code-helper.git"
  },
  "bin": {
    "code-helper": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs/最佳实践指南.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.js",
    "check": "npm run build && node dist/index.js check",
    "sync:local": "npm run build && node dist/index.js sync-local && npm run check",
    "prepack": "npm run build"
  },
  "keywords": [
    "agent",
    "workflow",
    "codex",
    "claude",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
