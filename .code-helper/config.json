    "userRules": "code-helper-docs/user-rules",
    "planDoc": "code-helper-docs/plan-doc",
    "resultDoc": "code-helper-docs/result-doc",
    "statusDoc": "code-helper-docs/status-doc"
  },
  "features": {
    "memoryTuning": {
      "enabled": true
    },
